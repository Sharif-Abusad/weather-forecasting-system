# ─── ERA5 / Copernicus CDS API ─────────────────────────────────────────────
# Get your key from: https://cds.climate.copernicus.eu/user
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=YOUR-UID:YOUR-API-KEY

# ─── Open-Meteo (no key needed — leave as is) ──────────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ─── Location — Azamgarh ───────────────────────────────────────────────────
LATITUDE=26.04
LONGITUDE=83.11
TIMEZONE=Asia/Kolkata

# ─── Paths ─────────────────────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
MODEL_XGBOOST_DIR=models/xgboost
MODEL_LSTM_DIR=models/lstm
SCALER_DIR=models/scalers

# ─── Model filenames ───────────────────────────────────────────────────────
XGBOOST_MODEL_FILE=rain_model.json
XGBOOST_META_FILE=model_meta.json
LSTM_MODEL_FILE=lstm_temp_model.keras
LSTM_META_FILE=model_meta.json
SCALER_FILE=lstm_temp_scaler.pkl

# ─── Flask ─────────────────────────────────────────────────────────────────
FLASK_APP=app/main.py
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000
SECRET_KEY=change-this-to-a-random-secret-key

# ─── Forecast settings ─────────────────────────────────────────────────────
FORECAST_N=5
LOOKBACK=24